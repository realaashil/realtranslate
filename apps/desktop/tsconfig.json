{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strict": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src", "forge.config.ts", "forge.env.d.ts", "vite.*.config.ts"]
}
