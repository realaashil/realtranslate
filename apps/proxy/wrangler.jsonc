{
  "name": "realtime-translate-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-11",
  "migrations": [
    {
      "new_sqlite_classes": ["MyDurableObject"],
      "tag": "v1"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MyDurableObject",
        "name": "MY_DURABLE_OBJECT"
      }
    ]
  },
  "vars": {
    "JWT_SECRET": "replace-me",
    "GEMINI_API_KEY": ""
  },
  "observability": {
    "enabled": true
  }
}
